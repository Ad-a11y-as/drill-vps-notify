# VMISS account
VMISS_EMAIL=
VMISS_PASSWORD=

# VMISS product
VMISS_STORE_URL=https://app.vmiss.com/store/us-los-angeles-cn2
VMISS_TARGET_PRODUCT=US.LA.CN2.Basic
VMISS_LOGIN_URL=https://app.vmiss.com/login

# Runtime
CHECK_INTERVAL_SECONDS=30
HEADLESS=false
PLAYWRIGHT_USER_DATA_DIR=.browser-profile
CLOUDFLARE_WAIT_SECONDS=900

# Message API
MESSAGE_CLOUD_DOMAIN=
MESSAGE_APP_ID=
MESSAGE_APP_SECRET=
MESSAGE_PERMANENT_CODE=
MESSAGE_TO_USERS=

# Token refresh follows provider rule:
# 0-6600 seconds returns the same token; 6600-7200 seconds can renew.
TOKEN_REFRESH_AFTER_SECONDS=6600
